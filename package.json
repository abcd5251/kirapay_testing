{
  "name": "create-cf-planetscale-app",
  "version": "2.0.0",
  "description": "Create an app for building production ready RESTful APIs using Hono and Drizzle",
  "main": "dist/index.mjs",
  "engines": {
    "bun": ">=1.1.29"
  },
  "license": "MIT",
  "keywords": [
    "boilerplate",
    "template",
    "starter",
    "example",
    "vitest",
    "hono",
    "api",
    "rest",
    "sql",
    "jwt",
    "es6",
    "es7",
    "es8",
    "es9",
    "jwt",
    "zod",
    "eslint",
    "prettier"
  ],
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "build": "bun build --target=bun --sourcemap --outdir ./out src/main.ts --format=esm",
    "start": "bun run build && bun out/main.js",
    "test": "vitest run",
    "test:coverage": "vitest --coverage --coverage.provider istanbul --coverage.include src/ run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check **/*.ts",
    "prettier:fix": "prettier --write **/**/*.ts",
    "prepare": "husky"
  },
  "type": "module",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.4.25",
    "@cloudflare/workers-types": "^4.20240821.1",
    "@faker-js/faker": "^8.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/eslint__js": "^8.42.3",
    "@typescript-eslint/parser": "^8.2.0",
    "clock-mock": "^2.0.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "esbuild": "^0.23.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import-x": "^3.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^15.9.0",
    "husky": "^9.1.5",
    "mockdate": "^3.0.5",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vitest": "1.5.0"
  },
  "dependencies": {
    "@yidongw/pawx-schemas": "link:@yidongw/pawx-schemas",
    "@aws-sdk/client-ses": "^3.637.0",
    "@grammyjs/auto-chat-action": "^0.1.1",
    "@grammyjs/commands": "^1.0.5",
    "@grammyjs/hydrate": "^1.4.1",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/parse-mode": "^1.11.1",
    "@grammyjs/runner": "^2.0.3",
    "@neondatabase/serverless": "^0.9.5",
    "@planetscale/database": "^1.19.0",
    "@sentry/bun": "^10.24.0",
    "@smithy/types": "^3.3.0",
    "@tsndr/cloudflare-worker-jwt": "2.5.3",
    "@types/bun": "^1.1.9",
    "@types/lodash": "^4.17.16",
    "@vitest/coverage-istanbul": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "callback-data": "^1.1.1",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.33.0",
    "drizzle-zod": "^0.5.1",
    "grammy": "^1.35.0",
    "hono": "^4.5.8",
    "http-status": "^1.7.4",
    "https-proxy-agent": "^7.0.6",
    "iso-639-1": "^3.1.5",
    "lodash": "^4.17.21",
    "lru-cache": "^11.0.2",
